# ⚠️ 仅 DEMO 占位值——生产务必另行注入，绝不沿用。
# SYDOM_MASTER_KEY = base64(32 字节)；下值解码为 32 个 0x2a。
SYDOM_MASTER_KEY=KioqKioqKioqKioqKioqKioqKioqKioqKioqKioqKio=
SYDOM_ROOT_SECRET=demo-root-secret

# 主机发布端口（仅本机已占用时才需覆盖；留空走默认）。
# 例：本机已跑 Redis/PG 时取消注释改用空闲端口。
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# CP_ADMIN_HOST_PORT=8081
# CP_HEARTBEAT_HOST_PORT=8082
# SIDECAR_HOST_PORT=8090
# ORDERSERVICE_HOST_PORT=8080
